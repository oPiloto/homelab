DOMAIN=cloud.example.com

TZ=America/Sao_Paulo

## MariaDB
MYSQL_HOST=nextcloud-db
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_PUID=1000
MYSQL_PGID=1000

## Nextcloud
NC_ADMIN_USER=
NC_ADMIN_USER_PASSWORD=

## Reverse proxy (Traefik)
## Faixa de IP da rede "traefik" usada pelo container do Traefik para
## alcançar o Nextcloud. Ajuste caso a sub-rede real seja diferente
## (verifique com: docker network inspect traefik).
NC_TRUSTEDPROXIES=172.16.0.0/24
NC_OVERWRITEPROTOCOL=https

## Redis (cache/locking)
REDIS_HOST=nextcloud-redis
REDIS_PASSWORD=
